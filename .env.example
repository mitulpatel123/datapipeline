# --- Dhan Account 1: real-time/high-frequency (option chain, websocket, quote reconciliation) ---
DHAN_CLIENT_ID_1=
DHAN_ACCESS_TOKEN_1=

# --- Dhan Account 2: historical/reference/failover -- must NOT duplicate-poll Account 1's ---
# --- live endpoints (option chain / quote reconciliation). Optional: leave both blank to ---
# --- run with Account 1 only. ---
DHAN_CLIENT_ID_2=
DHAN_ACCESS_TOKEN_2=

# --- Telegram alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Storage ---
POSTGRES_URL=postgresql://localhost:5432/nifty_data
REDIS_URL=redis://localhost:6379/0

# --- Optional news/sentiment API. Leave blank to run without it -- the pipeline works fully ---
# --- without it, and the gap watchdog automatically stops watching news_sentiment when this ---
# --- is unset (no false "news never started" alerts). ---
MARKETAUX_API_KEY=

# --- Scheduler safety profile ---
# safe       -> option chain ~6s,   quote reconciliation ~15s  (Day 1 of the soak test)
# normal     -> option chain ~4s,   quote reconciliation ~10s  (Day 2)
# production -> option chain ~3.3s, quote reconciliation ~5-10s (Days 3-7, once safe/normal proved stable)
# ALWAYS start a new soak test on "safe". Never start directly in "production".
SOAK_MODE=safe

# --- Dhan rate limiting (code-enforced by connectors/dhan_request_manager.py, not just ---
# --- documented). These are GLOBAL per account across every endpoint (option chain, quotes, ---
# --- historical, etc.), not per endpoint. Defaults are intentionally conservative -- both ---
# --- Dhan accounts hit HTTP 429 during one heavy testing session before these existed. ---
DHAN_GLOBAL_RPS=4
DHAN_GLOBAL_BURST=1
DHAN_OPTIONCHAIN_MIN_INTERVAL_SECONDS=3.3
DHAN_MARKETQUOTE_MIN_INTERVAL_SECONDS=1.2

# Circuit breaker escalation on 429 / soft-ban warnings: 1st hit -> cooldown then reduced
# speed; 2nd hit -> longer cooldown + all other REST families disabled for the account;
# 3rd hit -> all REST disabled for the account until the next process restart.
DHAN_429_FIRST_COOLDOWN_SECONDS=60
DHAN_429_SECOND_COOLDOWN_SECONDS=300
DHAN_429_REDUCED_SPEED_MINUTES=15

# --- Single-orchestrator Redis lock -- prevents two orchestrator processes from both ---
# --- polling Dhan at once (see utils/process_lock.py). Do not run two terminals anyway. ---
ORCHESTRATOR_LOCK_TTL_SECONDS=60

# --- Gap watchdog alert cooldown -- once a gap fires an alert, wait this long before ---
# --- alerting again on the SAME ongoing gap (per-stream grace periods before the first ---
# --- alert are hardcoded per data type in storage/gap_watchdog.py, not a single global knob). ---
GAP_ALERT_COOLDOWN_SECONDS=600

# --- WebSocket option-chain universe: subscribe to a live ATM +/- N strike window (both ---
# --- CE/PE) in addition to NIFTY/futures/heavyweight stocks. ---
ENABLE_OPTION_WEBSOCKET_UNIVERSE=true
OPTION_WS_ATM_STRIKES_EACH_SIDE=10

# --- NSE trading holiday calendar (IST dates). Missing/empty file just falls back to ---
# --- weekend-only skipping -- see config/nse_holidays.json. ---
NSE_HOLIDAY_FILE=config/nse_holidays.json
