DHAN_CLIENT_ID_1=
DHAN_ACCESS_TOKEN_1=
DHAN_CLIENT_ID_2=
DHAN_ACCESS_TOKEN_2=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
POSTGRES_URL=postgresql://localhost:5432/nifty_data
REDIS_URL=redis://localhost:6379/0
MARKETAUX_API_KEY=

# Scheduler safety profile: safe -> normal -> production. Start every soak test on
# safe and only move faster once a session has proven stable. See README.
SOAK_MODE=safe

# Dhan rate limiting -- these are GLOBAL per account across every endpoint, not per
# endpoint. Kept conservative (below Dhan's documented limits) after both accounts
# hit HTTP 429 during heavy testing.
DHAN_GLOBAL_RPS=4
DHAN_GLOBAL_BURST=1
DHAN_OPTIONCHAIN_MIN_INTERVAL_SECONDS=3.3
DHAN_MARKETQUOTE_MIN_INTERVAL_SECONDS=1.2
DHAN_429_FIRST_COOLDOWN_SECONDS=60
DHAN_429_SECOND_COOLDOWN_SECONDS=300
DHAN_429_REDUCED_SPEED_MINUTES=15

ORCHESTRATOR_LOCK_TTL_SECONDS=60
GAP_ALERT_COOLDOWN_SECONDS=600

ENABLE_OPTION_WEBSOCKET_UNIVERSE=true
OPTION_WS_ATM_STRIKES_EACH_SIDE=10

NSE_HOLIDAY_FILE=config/nse_holidays.json
